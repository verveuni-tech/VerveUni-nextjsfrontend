rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All reads and writes go through Firebase Admin SDK (server-side BFF),
    // which bypasses these rules entirely. Lock down client-side access.

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Users can read their own profile. Admins can read/write all.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Admin SDK only
    }

    match /organizations/{organizationId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /organizationMembers/{membershipId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /batches/{batchId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /batchMembers/{membershipId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /questionSets/{questionSetId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /questions/{questionId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /sessions/{sessionId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /sessionAnswers/{answerId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /sessionAnalyses/{sessionId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /organizationInvites/{inviteId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }

    match /batchInvites/{inviteId} {
      allow read: if signedIn();
      allow write: if false; // Admin SDK only
    }
  }
}
